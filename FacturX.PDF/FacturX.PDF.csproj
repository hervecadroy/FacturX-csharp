<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;netstandard2.1;net462;net480;net8.0</TargetFrameworks>
    <Authors>FacturX-CSharp Contributors</Authors>
    <Company></Company>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>FacturX.PDF-csharp</PackageId>
    <PackageReadmeFile></PackageReadmeFile>
    <RepositoryUrl>https://github.com/hervecadroy/FacturX-csharp/</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <IncludeSymbols>True</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    <RootNamespace>FacturX.PDF</RootNamespace>
    <Version>1.0.0</Version>
    <PackageReleaseNotes>1.0.0
* Fork of ZUGFeRD-csharp as FacturX-CSharp - fully open-source under Apache-2.0</PackageReleaseNotes>
    <AssemblyName>FacturX.PDF</AssemblyName>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <Description>FacturX-CSharp is an open-source C# library for reading, creating and processing ZUGFeRD / Factur-X / XRechnung electronic invoices.

This library allows to load and create PDF/A files containing FacturX invoice data.
    </Description>
    <Copyright>Apache-2.0 - Fork of ZUGFeRD-csharp by Stephan Stapel</Copyright>
    <PackageProjectUrl>https://github.com/hervecadroy/FacturX-csharp/</PackageProjectUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <SignAssembly>True</SignAssembly>
    <AssemblyOriginatorKeyFile>FacturX.PDF.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Resources\sRGB-IEC61966-2.1.icc" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\PdfMetadataTemplate-2.0.xml" />
    <EmbeddedResource Include="Resources\PdfMetadataTemplate-2.3.xml" />
    <EmbeddedResource Include="Resources\PdfMetadataTemplate-1.0.xml" />
    <EmbeddedResource Include="Resources\sRGB-IEC61966-2.1.icc" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PDFsharp-extended" Version="1.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FacturX\FacturX.csproj" />
  </ItemGroup>

  <!-- netstandard: minimal & stabil -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0' &#xD;&#xA;                      Or '$(TargetFramework)' == 'netstandard2.1'">
    <PackageReference Include="System.Text.Encoding.CodePages" Version="4.7.1" />
  </ItemGroup>

  <!-- .NET Framework -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net462' &#xD;&#xA;                      Or '$(TargetFramework)' == 'net480'">
    <PackageReference Include="System.Text.Encoding.CodePages" Version="4.7.1" />
  </ItemGroup>

  <!-- .NET -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="System.Text.Encoding.CodePages" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0' Or '$(TargetFramework)' == 'netstandard2.1' Or '$(TargetFramework)' == 'netstandard2.0'">
    <InternalsVisibleTo Include="FacturX.PDF.Test" PublicKey="" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net462' Or '$(TargetFramework)' == 'net480'">
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>
        FacturX.PDF.Test, </_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>